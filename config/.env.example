# ============================================
# LEAD FINDER - Konfiguration
# ============================================

# Google Places API Key
# Hol dir einen Key: https://console.cloud.google.com/apis/credentials
# Aktiviere "Places API" und "Places API (New)" in der Google Cloud Console
GOOGLE_PLACES_API_KEY=DEIN_API_KEY_HIER

# Suchparameter
SEARCH_QUERIES=Massagepraxis,Massage Studio,Thai Massage,Physiotherapie,Wellness Massage
SEARCH_CENTER_LAT=49.2389
SEARCH_CENTER_LNG=9.1008
SEARCH_RADIUS_KM=50

# Website-Check Einstellungen
REQUEST_TIMEOUT=10
MAX_CONCURRENT_CHECKS=5
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Scoring
MIN_SCORE_FOR_HOT_LEAD=20
MIN_REVIEWS_FOR_BONUS=30

# Output
OUTPUT_DIR=./output
OUTPUT_FORMAT=csv
